## Example environment variables for TorneoApp

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/torneoapp

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret

# Social providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# App
PORT=3000
